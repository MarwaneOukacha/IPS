package com.paylogic.ama.iso20022.processor.outgoing;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Component;

import com.gms.utils.exception.BusinessException;
import com.gms.utils.exception.MandatoryFieldEx;
import com.paylogic.ama.iso20022.bo.pacs002.DocumentPacs002;
import com.paylogic.ama.iso20022.bo.pacs028.DocumentPacs028;
import com.paylogic.ama.iso20022.converter.incoming.Pacs002IncomingConverter;
import com.paylogic.ama.iso20022.converter.outgoing.Pacs028OutgoingConverter;
import com.paylogic.ama.iso20022.util.CoreUtil;
import com.paylogic.ama.core.model.MemberEndPoint;
import com.paylogic.ama.core.model.Payment;

@Component("Pacs028OutgoingProcessor")
public class Pacs028OutgoingProcessor extends OutgoingProcessor<DocumentPacs028, DocumentPacs002>{
	@Autowired
	private Pacs028OutgoingConverter pacs028Converter;
	@Autowired
	private Pacs002IncomingConverter pacs002Converter;
	
	
	@Override
	protected void initRequestMandatoryField() {
		mandatoryFields.add(CoreUtil.PAYMENT_ISS_TRXREF);
		mandatoryFields.add(CoreUtil.PAYMENT_VOUCHER);
		mandatoryFields.add(CoreUtil.PAYMENT_CREATE_TIME);
		mandatoryFields.add(CoreUtil.PAYMENT_FROMMEMBER);
		mandatoryFields.add(CoreUtil.PAYMENT_TOMEMBER);
	}
	
	@Override
	protected void validateAccounts(Payment payment, MemberEndPoint destinationEndPoint) throws MandatoryFieldEx {
		//nothing to do
	}
	
	@Override
	protected DocumentPacs028 convertRequest(Payment incoming, MemberEndPoint destinationEndPoint) {
		return pacs028Converter.convertPayment(incoming, destinationEndPoint.getParamCategories());
	}
	
	@Override
	protected void validateResponse(DocumentPacs002 response, MemberEndPoint destinationEndPoint) throws BusinessException {
		
	}
	
	@Override
	protected Payment convertResponse(DocumentPacs002 response, Payment initialRequest, MemberEndPoint destinationEndPoint) throws BusinessException { 
		return pacs002Converter.convertToPaymentResponse(response, destinationEndPoint.getParamCategories(),initialRequest);
	}
	
	@Override
	protected Class<DocumentPacs002> initP2Class() {
		return DocumentPacs002.class;
	}
}
