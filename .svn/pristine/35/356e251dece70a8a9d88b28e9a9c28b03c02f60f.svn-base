package com.paylogic.ama.iso20022.processor.incoming;

import java.io.IOException;
import java.util.Date;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Component;

import com.gms.utils.exception.BusinessException;
import com.gms.utils.net.webinterface.ErrorStatus;
import com.gms.utils.net.webinterface.WebRequest;
import com.paylogic.ama.iso20022.bo.BaseDocument;
import com.paylogic.ama.iso20022.bo.pacs008.DocumentPacs008;
import com.paylogic.ama.iso20022.converter.incoming.Pacs008IncomingConverter;
import com.paylogic.ama.iso20022.converter.outgoing.Pacs002OutgoingConverter;
import com.paylogic.ama.iso20022.store.IsoParameterStore;
import com.paylogic.ama.iso20022.util.CoreUtil;
import com.paylogic.ama.iso20022.validator.Pacs008Validator;
import com.paylogic.ama.core.exception.HostTimeOutException;
import com.paylogic.ama.core.exception.HostUnreachableException;
import com.paylogic.ama.core.exception.RemoteEndPointException;
import com.paylogic.ama.core.iso20022.model.PaymentExtended;
import com.paylogic.ama.core.model.MemberEndPoint;
import com.paylogic.ama.core.model.Payment;
import com.paylogic.ama.endpoint.monitor.HandlerMonitor;

@Component("urn:iso:std:iso:20022:tech:xsd:pacs.008.001.11")
public class Pacs008IncomingProcessor extends IncomingProcessor<Payment, PaymentExtended>{
	@Autowired
	protected Pacs008IncomingConverter pacs008Converter;
	@Autowired
	protected Pacs002OutgoingConverter pacs002Converter;
	@Autowired
    protected HandlerMonitor handlerMonitor;
	@Autowired
	protected IsoParameterStore paramStore;

	@Override
	protected Class<? extends BaseDocument> initRequestClass() {
		return DocumentPacs008.class;
	}

	@Override
	protected void validateRequest(BaseDocument document, MemberEndPoint destinationEndPoint) throws BusinessException {
		DocumentPacs008 incoming = (DocumentPacs008) document;
		Pacs008Validator.validate(incoming.getFIToFICstmrCdtTrf(),CoreUtil.YES.equals(paramStore.getPacs008KycMandatory()));
	}

	@Override
	protected Payment convertRequest(BaseDocument document, MemberEndPoint destinationEndPoint) {
		DocumentPacs008 incoming = (DocumentPacs008) document;
		Payment payment = pacs008Converter.convertPacs008(incoming, destinationEndPoint.getParamCategories());
		payment.setSendSourceHandler(handlerMonitor.getHandlerIden());
		return payment;
	}

	@Override
	protected PaymentExtended createRejectObject(String incoming, Exception ex, MemberEndPoint destinationEndPoint) {
		PaymentExtended payment = new PaymentExtended();
		payment.setState(CoreUtil.PAY_STATUS_REJECTED);
		payment.setRejectMessage(ex.getMessage());
		payment.setRejectCode(ex.getClass().getSimpleName());
		payment.setUpdateTime(new Date());
		return payment;
	}
	
	@Override
	protected void validateResponse(PaymentExtended response, MemberEndPoint destinationEndPoint) throws BusinessException {
		
	}
	
	@Override
	protected PaymentExtended handlerNotConnectedResponse(WebRequest webRequest, IOException ex) throws IOException {
		//return rejected Payment
		PaymentExtended payment = new PaymentExtended();
		payment.setState(CoreUtil.PAY_STATUS_REJECTED);
		payment.setRejectMessage(ex.getMessage());
		payment.setRejectCode(HostUnreachableException.class.getSimpleName());
		payment.setUpdateTime(new Date());
		return payment;
	}
	
	@Override
	protected PaymentExtended handlerTimeoutResponse(WebRequest webRequest, IOException ex) throws IOException {
		//return rejected Payment
		PaymentExtended payment = new PaymentExtended();
		payment.setState(CoreUtil.PAY_STATUS_SUSPECTED);
		payment.setRejectMessage(ex.getMessage());
		payment.setRejectCode(HostTimeOutException.class.getSimpleName());
		payment.setUpdateTime(new Date());
		return payment;
	}
	
	@Override
	protected PaymentExtended handlerNotOkResponse(WebRequest webRequest) throws RemoteEndPointException {
		//return rejected Payment
		PaymentExtended payment = new PaymentExtended();
		payment.setState(CoreUtil.PAY_STATUS_REJECTED);
		ErrorStatus status = webRequest.getconvertedResponse(ErrorStatus.class);
		if(status == null) {
			//may be ama got core dump
			status = ErrorStatus.INTERNAL_ERROR_STATUS;
		}
		payment.setRejectMessage(status.getErrorDescription());
		payment.setRejectCode(status.getError());
		payment.setUpdateTime(new Date());
		return payment;
	}
	
	@Override
	protected PaymentExtended handleNullResponse(WebRequest webRequest) throws RemoteEndPointException {
		//return rejected Payment
		PaymentExtended payment = new PaymentExtended();
		payment.setState(CoreUtil.PAY_STATUS_REJECTED);
		payment.setRejectMessage(ErrorStatus.INTERNAL_ERROR_STATUS.getErrorDescription());
		payment.setRejectCode(ErrorStatus.INTERNAL_ERROR_STATUS.getError());
		payment.setUpdateTime(new Date());
		return payment;
	}

	@Override
	protected BaseDocument convertDocumentResponse(PaymentExtended response, BaseDocument initialRequest, MemberEndPoint destinationEndPoint) {
		return pacs002Converter.convertFromPayment(response, destinationEndPoint.getParamCategories(),(DocumentPacs008)initialRequest);
	}
	
	@Override
	protected Class<PaymentExtended> initP2Class() {
		return PaymentExtended.class;
	}
}
